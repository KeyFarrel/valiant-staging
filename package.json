{
  "name": "valiant",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "overrides": {
    "jspdf": "^4.0.0"
  },
  "scripts": {
    "dev": "vite --host",
    "build-test": "npm run build && npm run test:headless",
    "build:development": "vite build --mode development",
    "preview:development": "vite preview --mode development",
    "build:staging": "vite build --mode staging",
    "preview:staging": "vite preview --mode staging",
    "build:production": "vite build --mode production",
    "preview:production": "vite preview --mode production",
    "test": "npm run test:unit",
    "test:unit": "vitest",
    "vite:inspect": "npx serve .vite-inspect",
    "rollup:inspect": "npx serve .rollup-inspect",
    "sonar": "sonar-scanner",
    "coverage": "vitest run --coverage",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "help": "node src/scripts/log-help.js"
