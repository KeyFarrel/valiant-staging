{
  "files": [],     
  "compilerOptions": {
    "types": ["vitest/globals"],
    "module": "CommonJS",
    "target": "ES5",
    "sourceMap": true,
    "baseUrl": "./",
    "paths": {
      "actions" :["src/service/peta-service"]
    },
    "forceConsistentCasingInFileNames": true, //tambahan acep
    //"moduleResolution": "node",//tambahan acep
    "lib": [
      "DOM",
      "ES6",
      "ES5",
      "ESNext"
    ]
  },  
  // "include": ["src/**/*"],
  "exclude": ["node_modules", "src/**/*.spec.ts"], 
  "references": [
    {
      "path": "./tsconfig.node.json"
    },
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.vitest.json"
    }
  ]
}
