{
  "files": [],     
  "compilerOptions": {
    "types": ["jest", "node"],
    "module": "CommonJS",
    "target": "ES5",
    "sourceMap": true,
    "baseUrl": "./",
    "paths": {
      "actions" :["src/service/peta-service"],
      "@/*": ["./src"]
    },
    "forceConsistentCasingInFileNames": true, //tambahan acep
    //"moduleResolution": "node",//tambahan acep
    "lib": [
      "DOM",
      "ES6",
      "ES5",
      "ESNext"
    ]
  },  
  "exclude": ["node_modules"], 
  "references": [
    {
      "path": "./tsconfig.node.json"
    },
    {
      "path": "./tsconfig.app.json"
    },
  ]
}
