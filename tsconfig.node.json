{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext", // CommonJS for Node.js compatibility
    "moduleResolution": "NodeNext", // Standard module resolution for Node.js
    "target": "ESNext",
    "lib": ["ESNext"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true, // Enable JSON module resolution
    "composite": true,
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["jest.config.ts", "src/**/*.ts", "src/**/__tests__/*",  "src/**/*.json"],
  "exclude": ["node_modules", "tsconfig.app.json"]
}
