{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext", // Vite uses ESNext modules
    "moduleResolution": "Node", // Vite works with standard Node resolution
    "target": "ESNext",
    "lib": ["DOM", "ESNext"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "composite": true,
    "resolveJsonModule": true, // Enable JSON module resolution
    "paths": {
      "@/*": ["src/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.vue", "src/**/*.json"],
  "exclude": ["node_modules", "tsconfig.node.json"]
}
